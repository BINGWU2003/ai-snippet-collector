{
  "name": "ai-snippet-collector",
  "displayName": "AI Snippet Collector",
  "description": "Collect and organize code snippets into Markdown prompt files for AI assistants.",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "BINGWU2003",
  "author": {
    "name": "BINGWU2003",
    "email": "hujiacheng2003@163.com"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/BINGWU2003/ai-snippet-collector"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-snippet.addToSpecificFile",
        "title": "%command.addToSpecificFile.title%"
      },
      {
        "command": "ai-snippet.addToLastFile",
        "title": "%command.addToLastFile.title%"
      },
      {
        "command": "ai-snippet.deleteSnippet",
        "title": "%command.deleteSnippet.title%"
      },
      {
        "command": "ai-snippet.gotoSnippetSource",
        "title": "%command.gotoSnippetSource.title%"
      },
      {
        "command": "ai-snippet.expandReference",
        "title": "%command.expandReference.title%"
      },
      {
        "command": "ai-snippet.collapseReference",
        "title": "%command.collapseReference.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "aiSnippetCollector.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh-cn"
          ],
          "enumDescriptions": [
            "%configuration.language.enum.auto%",
            "%configuration.language.enum.en%",
            "%configuration.language.enum.zhCn%"
          ],
          "default": "auto",
          "description": "%configuration.language.description%"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "ai-snippet.addToLastFile",
          "group": "1_modification@1"
        },
        {
          "command": "ai-snippet.addToSpecificFile",
          "group": "1_modification@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ai-snippet.addToLastFile",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "ai-snippet.addToSpecificFile",
        "key": "ctrl+alt+shift+a",
        "mac": "cmd+alt+shift+a",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "pnpm run package && vsce package --allow-missing-repository",
    "compile-prompt": "tsx scripts/compile-prompt.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
